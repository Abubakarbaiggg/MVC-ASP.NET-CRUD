@model AdminDashboard_UI.Models.Products

@{
	ViewData["Title"] = "Update Product";
}
<div class="text-center">
	<h1 class="display-4">Update Product</h1>
</div>
<form asp-controller="Product" asp-action="UpdateProductItem" method="post">
    <input type="hidden"  value="@Model.ProductId" name="productId">
    <div class="form-group">
        <label for="name">Product Name</label>
        <input type="text" name="name" value="@Model.Name" class="form-control" id="name" placeholder="Enter product name">
    </div>
    <div class="form-group">
        <label for="description">Description</label>
        <input type="text" name="description" value="@Model.Description" class="form-control" id="description" placeholder="Enter description">
    </div>
    <div class="form-group">
        <label for="price">Price</label>
        <input type="number" name="price" value="@Model.Price" class="form-control" id="price" placeholder="Enter price">
    </div>
    <div class="form-group">
        <label for="color">Color</label>
        <input type="text" name="color" value="@Model.Color" class="form-control" id="color" placeholder="Enter color">
    </div>
    <button type="submit" class="btn btn-primary">Update Product</button>
</form>